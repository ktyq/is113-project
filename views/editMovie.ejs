<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Movie</title>
  <link rel="stylesheet" href="/default.css">

  <style>
  body {
    background-color: #f8f9fb;
    margin: 0;
    padding: 20px;
  }

  /* Container */
  .container {
    max-width: 650px;
    margin: auto;
    background: #fff;
    padding: 25px;
    border-radius: 8px;
    border: 1px solid #e0e0e0;
  }

  /* Title */
  h2 {
    margin-bottom: 15px;
  }

  /* Labels */
  label {
    display: block;
    margin-top: 12px;
    font-weight: 600;
  }

  /* Inputs */
  input,
  textarea {
    width: 100%;
    padding: 8px 10px;
    margin-top: 5px;
    border: 1px solid #ccc;
    border-radius: 4px;
  }

  /* Textarea */
  textarea {
    min-height: 80px;
  }

  /* Image Preview */
  .preview {
    margin-bottom: 15px;
  }

  .preview img {
    width: 240px;
    height: 360px;
    object-fit: cover;
    border-radius: 6px;
    border: 1px solid #ddd;
  }

  /* Buttons */
  .button-group {
    margin-top: 20px;
    display: flex;
    justify-content: flex-start;
    gap: 10px;
    align-items: center;
  }

  .button-group button,
  .button-group a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 36px;
    padding: 0 14px;
    border-radius: 4px;
    font-size: 14px;
    text-decoration: none;
  }

  .button-group button {
      margin-top: 8px;
  }

  /* Save button */
  .save-btn {
    background-color: #2c7be5;
    color: white;
    border: none;
    padding: 8px 14px;
    border-radius: 4px;
  }

  .save-btn:hover {
    background-color: #1a5edb;
  }

  /* Cancel button */
  .cancel-btn {
    background-color: #e0e0e0;
    color: black;
    padding: 8px 14px;
    border-radius: 4px;
    text-decoration: none;
  }

  .cancel-btn:hover {
    background-color: #cfcfcf;
  }
  </style>
</head>

<body>
  <%- include('partial/header', { user: user }) %>
  <div style="padding-left: 5%;">
    <h2>Edit Movie</h2>

    <!-- OPTIONAL: Movie Image Preview -->
    <div class="preview">
      <img src="/uploads/<%= movie.imageRef %>" alt="<%= movie.title %>">
    </div>

    <form action="/admin/edit?id=<%= movie._id %>" method="POST" enctype="multipart/form-data">

      <label>Title</label>
      <input type="text" name="title" value="<%= movie.title %>" required>

      <label>Image URL</label>
      <input type="file" name="image" accept="image/*">

      <label>Genre</label>
      <input type="text" name="genre" value="<%= movie.genre.join(', ') %>" required>

      <label>Release Year</label>
      <input type="number" name="release_year" value="<%= movie.release_year %>" required>

      <label>Duration (minutes)</label>
      <input type="number" name="movieLength" value="<%= movie.movieLength %>" required>

      <label>Director</label>
      <input type="text" name="director" value="<%= movie.director.join(', ') %>" required>

      <label>Cast</label>
      <input type="text" name="cast" value="<%= movie.cast.join(', ') %>" required>

      <label>Overview</label>
      <textarea name="overview" required><%= movie.overview %></textarea>

      <div class="button-group">
        <button type="submit" class="save-btn">Update Movie</button>
        <a href="/admin" class="cancel-btn">Cancel</a>
      </div>

    </form>
  </div>
</body>

</html>