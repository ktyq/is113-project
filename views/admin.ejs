<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - Movie Management</title>
  <link rel="icon" type="image/x-icon" href="favicon.ico">
  <link rel="stylesheet" href="/default.css">

  <style>
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background-color: #f4f4f9;
      margin: 0;
      padding: 20px;
      color: #333;
    }

    h2 {
      color: #2c3e50;
      margin-bottom: 15px;
    }

    form label {
      display: block;
      margin-top: 15px;
      font-weight: bold;
    }

    form input[type="text"],
    form input[type="number"],
    form textarea {
      width: 100%;
      padding: 10px;
      margin-top: 5px;
      border: 1px solid #ccc;
      border-radius: 6px;
      font-size: 14px;
    }

    form textarea {
      resize: vertical;
      min-height: 60px;
    }

    table {
        width: 50%;
    }

    form[action="/admin"] {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
    }

    form[action="/admin"] input[type="text"] {
    padding: 6px 10px;
    font-size: 14px;
    width: 40%;
    }

    form[action="/admin"] button {
    padding: 6px 12px;
    cursor: pointer;
    }



    /* Responsive */
    @media (max-width: 600px) {

      form input[type="text"],
      form input[type="number"],
      form textarea {
        font-size: 16px;
      }

      section form button {
        width: 100%;
      }
    }
  </style>
  <script>
    document.querySelector("form[action='/admin/add']").addEventListener("submit", function(e) {
        const title = document.querySelector("input[name='title']").value.trim();
        const year = parseInt(document.querySelector("input[name='release_year']").value);
        const duration = parseInt(document.querySelector("input[name='movieLength']").value);
        const genre = document.querySelector("input[name='genre']").value.trim();

        if (!title || !genre) {
        alert("Title and Genre cannot be empty!");
        e.preventDefault();
        return;
        }

        if (year < 1888 || year > 2100) {
        alert("Release year must be between 1888 and 2100");
        e.preventDefault();
        return;
        }

        if (duration <= 0 || duration > 500) {
        alert("Duration must be between 1 and 500 minutes");
        e.preventDefault();
        return;
        }
    });
  </script>
</head>

<body>
  <%- include('partial/header', { user: user }) %>

    <h2>Add New Movie</h2>

    <form action="/admin/add" method="POST" enctype="multipart/form-data">
      <label>Title</label>
      <input type="text" name="title" required>

      <label>Image URL</label>
      <input type="file" name="image" accept="image/*" required>

      <label>Genre</label>
      <input type="text" name="genre" placeholder="Action, Drama" required>

      <label>Release Year</label>
      <input type="number" name="release_year" required min="1888" max="2100">

      <label>Duration (minutes)</label>
      <input type="number" name="movieLength" required min="1" max="500">

      <label>Director</label>
      <input type="text" name="director" placeholder="Comma separated" required>

      <label>Cast</label>
      <input type="text" name="cast" placeholder="Comma separated" required>

      <label>Overview</label>
      <textarea name="overview" required></textarea>

      <button type="submit">Add Movie</button>
    </form>

    <h2>Search Movies</h2>

    <form method="GET" action="/admin">
      <input type="text" name="search" placeholder="Search by title..." value="<%= search || '' %>">
      <button type="submit">Search</button>
    </form>

    <h2>Movie List</h2>
    <% if (!movies || movies.length === 0) { %>
    <p>No movies found.</p>
    <% } else { %>

    <table border="1">
    <thead>
        <tr>
        <th>Poster</th>
        <th>Title</th>
        <th>Year</th>
        <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        <% movies.forEach(movie => { %>
        <tr>
        <!-- IMAGE -->
        <td>
            <img src="/uploads/<%= movie.imageRef %>" 
                style="width:60px; height:90px; object-fit:cover;">
        </td>

        <!-- TITLE -->
        <td>
            <%= movie.title %>
        </td>

        <!-- YEAR -->
        <td>
            <%= movie.release_year %>
        </td>

        <!-- ACTIONS -->
        <td>
            <a href="/admin/edit?id=<%= movie._id %>">Edit</a>
            |
            <a href="/admin/delete?id=<%= movie._id %>">Delete</a>
        </td>
        </tr>
        <% }) %>
    </tbody>
    </table>

    <% } %>

</body>

</html>