<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Feedback</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="stylesheet" href="/default.css">
</head>

<body>
    <%- include('partial/header', { user: user }) %>

    <h1>Feedback</h1>

    <main>
        <section>
            <h2>Submit Feedback</h2>
            <form action="/feedback" method="POST">
                <div class="row">
                    <label>Type*</label>
                    <select name="type" required>
                        <option value="" disabled selected>Select type</option>
                        <option value="feedback">Feedback</option>
                        <option value="bug">Bug Report</option>
                        <option value="report">User Report</option>
                    </select>
                </div>

                <div class="row">
                    <label>Related URL (optional)</label>
                    <input type="text" name="url" placeholder="e.g. http://localhost:8000/index/view?movieId=69ce41694eaa99a98b417ed8">
                </div>

                <div class="row">
                    <label>Comments*</label><br>
                    <textarea name="notes" maxlength="256" placeholder="Describe your feedback..." required style="width: 100%; min-height: 80px;"></textarea>
                </div>

                <button type="submit">Submit Feedback</button>
            </form>
        </section>

        <hr>

        <section>
            <h2>My Past Feedback</h2>

            <% if (feedbacks && feedbacks.length > 0) { %>
                <table border="1">
                    <thead>
                        <tr>
                            <th>Type</th>
                            <th>Notes</th>
                            <th>URL</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% feedbacks.forEach(function(fb) { %>
                            <tr>
                                <td><strong><%= fb.type %></strong></td>
                                <td><%= fb.notes %></td>
                                <td>
                                    <% if (fb.url) { %>
                                        <a href="<%= fb.url %>">Link</a>
                                    <% } else { %>
                                        -
                                    <% } %>
                                </td>
                                <td><%= fb.status %></td>
                                <td><%= fb.createdAt.toLocaleDateString() %></td>
                                <td>
                                    <form action="/feedback/delete/<%= fb._id %>" method="POST" onsubmit="return confirm('Delete this feedback?')">
                                        <button type="submit" style="color: red;">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } else { %>
                <p>You haven't submitted any feedback yet.</p>
            <% } %>
        </section>
    </main>
</body>

</html>