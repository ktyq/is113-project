<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Feedback</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="stylesheet" href="/default.css">
  <style>
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background-color: #f4f4f9;
      margin: 0;
      padding: 20px;
      color: #333;
    }

    h2 {
      color: #2c3e50;
      margin-bottom: 15px;
    }

    section {
      background-color: #fff;
      padding: 20px;
      margin-bottom: 30px;
      border-radius: 10px;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }

    form label {
      display: block;
      margin-top: 15px;
      font-weight: bold;
    }

    form input[type="text"],
    form select,
    form textarea {
      width: 100%;
      padding: 10px;
      margin-top: 5px;
      border: 1px solid #ccc;
      border-radius: 6px;
      font-size: 14px;
      box-sizing: border-box;
    }

    form textarea {
      resize: vertical;
      min-height: 80px;
    }

    .btn {
      padding: 8px 16px;
      border: none;
      color: white;
      font-size: 14px;
      border-radius: 6px;
      cursor: pointer;
      transition: background-color 0.3s ease;
    }

    .btn-primary {
      background-color: #3498db;
      margin-top: 20px;
      padding: 12px 20px;
      font-size: 16px;
    }

    .btn-primary:hover {
      background-color: #2980b9;
    }

    .btn-danger {
      background-color: #e74c3c;
    }

    .btn-danger:hover {
      background-color: #c0392b;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 10px;
    }

    table th,
    table td {
      padding: 12px 15px;
      text-align: left;
      border-bottom: 1px solid #ddd;
    }

    table th {
      background-color: #2c3e50;
      color: white;
    }

    table tr:hover {
      background-color: #f5f5f5;
    }

    .status-pending {
      color: #e67e22;
      font-weight: bold;
    }

    .status-resolved {
      color: #27ae60;
      font-weight: bold;
    }

    .type-badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 12px;
      font-size: 12px;
      font-weight: bold;
      color: white;
    }

    .type-feedback {
      background-color: #3498db;
    }

    .type-bug {
      background-color: #e74c3c;
    }

    .type-report {
      background-color: #9b59b6;
    }

    .empty-message {
      text-align: center;
      color: #999;
      padding: 30px;
    }

    @media (max-width: 600px) {

      table,
      thead,
      tbody,
      th,
      td,
      tr {
        display: block;
      }

      thead tr {
        display: none;
      }

      td {
        padding: 8px 15px;
        border: none;
      }

      td::before {
        content: attr(data-label);
        font-weight: bold;
        display: block;
        margin-bottom: 3px;
      }

      tr {
        border-bottom: 2px solid #ddd;
        margin-bottom: 10px;
      }
    }
  </style>
</head>

<body>
  <%- include('partial/header', { user: user }) %>

  <h1>Feedback</h1>

  <!-- Submit Feedback Form -->
  <section>
    <h2>Submit Feedback</h2>
    <form action="/feedback" method="POST">

      <label>Type</label>
      <select name="type" required>
        <option value="" disabled selected>Select type</option>
        <option value="feedback">Feedback</option>
        <option value="bug">Bug Report</option>
        <option value="report">User Report</option>
      </select>

      <label>Related URL (optional)</label>
      <input type="text" name="url" placeholder="e.g. /movie/view?id=...">

      <label>Notes</label>
      <textarea name="notes" maxlength="256" placeholder="Describe your feedback, bug, or report..." required></textarea>

      <button type="submit" class="btn btn-primary">Submit</button>
    </form>
  </section>

  <!-- My Feedback List -->
  <section>
    <h2>My Feedback</h2>

    <% if (feedbacks && feedbacks.length > 0) { %>
    <table>
      <thead>
        <tr>
          <th>Type</th>
          <th>Notes</th>
          <th>URL</th>
          <th>Status</th>
          <th>Date</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% feedbacks.forEach(function(fb) { %>
        <tr>
          <td data-label="Type">
            <span class="type-badge type-<%= fb.type %>"><%= fb.type %></span>
          </td>
          <td data-label="Notes"><%= fb.notes %></td>
          <td data-label="URL">
            <% if (fb.url) { %>
            <a href="<%= fb.url %>"><%= fb.url %></a>
            <% } else { %>
            -
            <% } %>
          </td>
          <td data-label="Status">
            <span class="status-<%= fb.status %>"><%= fb.status %></span>
          </td>
          <td data-label="Date"><%= fb.createdAt.toLocaleDateString() %></td>
          <td data-label="Actions">
            <form action="/feedback/delete/<%= fb._id %>" method="POST" onsubmit="return confirm('Delete this feedback?')">
              <button type="submit" class="btn btn-danger">Delete</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } else { %>
    <p class="empty-message">No feedback found.</p>
    <% } %>
  </section>

</body>

</html>