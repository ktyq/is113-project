<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="stylesheet" href="/default.css">
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f4f9;
            margin: 0;
            padding: 20px;
        }

        .movie-card {
            display: flex;
            margin-bottom: 20px;
            background: #fff;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        .movie-card img {
            width: 150px;
            object-fit: cover;
        }

        .movie-info {
            padding: 15px;
        }

        .movie-info h2 {
            margin: 0;
            margin-bottom: 10px;
        }

        .button-row button {
            margin-right: 10px;
            padding: 8px 12px;
            border: none;
            background-color: #3498db;
            color: #fff;
            border-radius: 5px;
            cursor: pointer;
        }

        .button-row button:hover {
            background-color: #2980b9;
        }

        .movie-overview {
            overflow: hidden;
            display: -webkit-box;
            -webkit-box-orient: vertical;
        }
    </style>
</head>
<body>
    <%- include('partial/header', {user: user}) %>

    <h1>All Movies</h1>

    <% if (movies && movies.length > 0) { %>
        <% movies.forEach(movie => { %>
            <section class="movie-card">
                <img src="<%= movie.imageRef %>" alt="<%= movie.title %>">
                <div class="movie-info">
                    <h2><a href="/movie/view?id=<%= movie._id %>"><%= movie.title %></a> (<%= movie.release_year %>)</h2>
                    <div>Genre: <%= movie.genre.join(', ') %></div>
                    <p>Rating: <%= movie.averageRating || 0 %> / 5</p>
                    <p class="movie-overview"><%= movie.overview %></p>

                    <div class="button-row">
                        <a href="/watchlist/add/<%= movie._id %>"><button>Add to Watchlist</button></a>
                        <a href="/watched/add/<%= movie._id %>"><button>Mark as Watched</button></a>
                    </div>
                </div>
            </section>
        <% }) %>
    <% } else { %>
        <p>No movies found.</p>
    <% } %>

</body>
</html>