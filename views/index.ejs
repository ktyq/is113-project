<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Home</title>
  <link rel="stylesheet" href="default.css">
  <style>
    .movie-card img {
      width: 150px;
      object-fit: cover;
    }

    .movie-info {
      padding: 15px;
    }

    .movie-info h2 {
      margin: 0;
      margin-bottom: 10px;
    }

    .button-row button {
      margin-right: 10px;
      padding: 8px 12px;
      border: none;
      background-color: #3498db;
      color: #fff;
      border-radius: 5px;
      cursor: pointer;
    }

    .button-row button:hover {
      background-color: #2980b9;
    }

    .movie-overview {
      overflow: hidden;
      display: -webkit-box;
      -webkit-box-orient: vertical;
    }

    .movie-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    .movie-card {
      display: flex;
      background: #fff;
      border-radius: 8px;
      overflow: hidden;
      /* box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1); */
    }

    .movie-card img {
      width: 150px;
      object-fit: cover;
    }
  </style>
</head>

<body>
  <%- include('partial/header', {user: user}) %>
  <form method="GET" action="/index">
    <input type="text" name="search" placeholder="Search movies..." value="<%= search || '' %>">
    <button type="submit">Search</button>
  </form>

  <% if (movies && movies.length > 0) { %>
  <div class="movie-grid">
    <% movies.forEach(movie => { %>
    <section class="movie-card">
      <img src="uploads/<%= movie.imageRef %>" alt="<%= movie.title %>">
      <div class="movie-info">
        <h2><a href="/movie/view?id=<%= movie._id %>"><%= movie.title %></a> (<%= movie.release_year %>)</h2>
        <div>Genre: <%= movie.genre.join(', ') %></div>
        <p>Rating: <%= movie.averageRating || 0 %> / 5</p>
        <p class="movie-overview"><%= movie.overview %></p>
      </div>
    </section>
    <% }) %>
  </div>
  <% } else { %>
  <p>No movies found.</p>
  <% } %>

</body>

</html>