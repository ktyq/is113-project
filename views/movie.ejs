<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= movie.title %></title>
  <link rel="stylesheet" href="/default.css">
  <style>
    .review-header {
    display: flex;
    align-items: center;
    gap: 15px; /* spacing between text and link */
    }

    .review-header a {
    color: #3498db;
    font-weight: bold;
    text-decoration: none;
    margin-right: 85%;
    }

    .review-header a:hover {
    text-decoration: underline;
    }
  </style>
</head>

<body>
  <%- include('partial/header', { user: user }) %>

  <section>
    <div class="movie-detail">
      <!-- Movie Poster -->
      <img src="/uploads/<%= movie.imageRef %>" alt="<%= movie.title %>" style="max-width:200px;">
      <div>
        <!-- Title -->
        <h2><%= movie.title %></h2>

        <!-- Year and Duration -->
        <p><%= movie.release_year %> - <%= movie.movieLength %> mins</p>

        <!-- Meta Info -->
        <div class="movie-meta">
          <div>Genre: <%= movie.genre.join(', ') %></div>
          <div> Average Rating:
            <% if (movie.averageRating !== undefined && movie.averageRating !== null) { %>
            <%= movie.averageRating %> / 5
            <% } else { %>
            No ratings yet
            <% } %></div>
        </div>

        <!-- Overview -->
        <p><%= movie.overview %></p>

        <!-- Director(s) -->
        <p><strong>Directed By:</strong> <%= movie.director.join(', ') %></p>

        <!-- Cast -->
        <p><strong>Cast:</strong> <%= movie.cast.join(', ') %></p>

        <!-- Watchlist Status -->
        <% if (!user) { %>
        <p>Please login to manage your watchlist.</p>
        <form action="/login" method="get">
          <button type="submit">Add to Watchlist</button>
        </form>
        <form action="/login" method="get">
          <button type="submit">Mark as Watched</button>
        </form>

        <% } else { %>
        <% if (status === 'planning') { %>
        <p style="color: orange;">
          You marked this movie as planning to watch.
        </p>
        <% } else if (status === 'watched') { %>
        <p style="color: green;">
          You marked this movie as watched.
        </p>
        <% } %>


        <!-- BUTTONS -->
        <% if (!status) { %>

        <!-- NULL -->
        <form action="/list/add" method="POST">
          <input type="hidden" name="movieId" value="<%= movie._id %>">
          <button type="submit">Add to Watchlist</button>
        </form>

        <form action="/list/edit" method="POST">
          <input type="hidden" name="movieId" value="<%= movie._id %>">
          <input type="hidden" name="status" value="watched">
          <button type="submit">Mark as Watched</button>
        </form>

        <% } else if (status === 'planning') { %>

        <!-- PLANNING -->
        <form action="/list/remove" method="POST">
          <input type="hidden" name="movieId" value="<%= movie._id %>">
          <button type="submit">Remove from Watchlist</button>
        </form>

        <form action="/list/edit" method="POST">
          <input type="hidden" name="movieId" value="<%= movie._id %>">
          <input type="hidden" name="status" value="watched">
          <button type="submit">Mark as Watched</button>
        </form>

        <% } else if (status === 'watched') { %>

        <!-- WATCHED -->
        <form action="/list/remove" method="POST">
          <input type="hidden" name="movieId" value="<%= movie._id %>">
          <button type="submit">Remove from Watchlist</button>
        </form>

        <form action="/list/edit" method="POST">
          <input type="hidden" name="movieId" value="<%= movie._id %>">
          <input type="hidden" name="status" value="planning">
          <button type="submit">Change to Planning</button>
        </form>

        <% } %>
        <% } %>
      </div>
  </section>

  <!-- Reviews Section -->
  <section>
    <div class="review-header">
      <span><%= reviewCount %> Reviews</span>

      <a href="/reviews?movieId=<%= movie._id %>">
        Leave a review
      </a>
    </div>
  </section>
</body>

</html>