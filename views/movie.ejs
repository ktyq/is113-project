<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= movie.title %></title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="stylesheet" href="/default.css">
</head>

<body>
    <section>
        <div class="movie-detail">

            <!-- Movie Poster -->
            <img src="<%= movie.imageRef %>" alt="<%= movie.title %>" style="max-width:200px;">
            <img src="../public/image/Hoppers.jpg" alt="">
            <div>
                <!-- Title -->
                <h2><%= movie.title %></h2>

                <!-- Year and Duration -->
                <p><%= movie.release_year %> - <%= movie.movieLength %> mins</p>

                <!-- Meta Info -->
                <div class="movie-meta">
                    <div>Genre: <%= movie.genre.join(', ') %></div>
                    <div>Average Rating: <%= movie.averageRating || 0 %> / 5</div>
                </div>

                <!-- Overview -->
                <p><%= movie.overview %></p>

                <!-- Director(s) -->
                <p><strong>Directed By:</strong> <%= movie.director.join(', ') %></p>

                <!-- Cast -->
                <p><strong>Cast:</strong> <%= movie.cast.join(', ') %></p>

                <!-- Action Buttons -->
                <div class="button-row">
                    <a href="/watchlist/add/<%= movie._id %>"><button>Add to Watchlist</button></a>
                    <a href="/watched/add/<%= movie._id %>"><button>Mark as Watched</button></a>
                </div>

            </div>
    </section>

        <!-- Reviews Section -->
        <section>
            <div class="review-header">
                <a href="/review/<%= movie._id %>"><%= movie.reviews ? movie.reviews.length : 0 %> Reviews</a>
                <a href="/review/<%= movie._id %>"><button>Add Review</button></a>
            </div>
        </section>
</body>

</html>