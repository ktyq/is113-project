<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Movie</title>
  <link rel="icon" type="image/x-icon" href="favicon.ico">
  <link rel="stylesheet" href="../public/default.css">
</head>

<body>
  <section>
    <h2>Add Review</h2>
    <% if (errors && errors.length>0){%>
    <ul style="color: red;">
      <%errors.forEach(e => {%> <li><%=e%></li><%})%
    </ul>
    <%}%>

      <% if (currentUser){%>
      <form action="/reviews/add" method="POST">
        <input type="hidden" name="movieID" value="<%=movie._id%>">
        <div class="review-form-row"><label>Rating</label>
          <select name="rating">
            <option value="1">1</option>
            <option value="2">2</option>
            <option value="3">3</option>
            <option value="4">4</option>
            <option value="5">5</option>
          </select>
        </div>

        <label>Comment</label>
        <textarea name="comment"></textarea>

        <div class="review-form-row"><input type="checkbox" name="isAnonymous"><label>Post anonymously</label></div>
        <button type="submit">Post review!</button>
      </form>
      <% }else {%>
      <p><a href="/auth/login">Log in</a> to write a review.</p>
      <% } %>
      <hr>
  </section>

  <section>
    <h2>Reviews (<%=reviews.length %>)</h2>
    <% if (reviews.length ===0) {%>
    <p>No reviews yet. Be the first!</p>
    <%}%>

    <% reviews.forEach(review=>{%>
    <div>
      <p>
        Rating: <%= review.rating%>/5</p>
      <p><%= review.comment%></p>
      <p>
        <i><% if (review.isAnonymous) { %>
          Anonymous
          <% } else { %>
          <%= review.userID.username %>
          <% } %>
          , <%= review.createdAt.toDateString() %></i>
      </p>

      <% if(currentUser && currentUser._id.toString()===review.userID._id.toString()){%>
      <details>
        <summary>Edit</summary>
        <form action="/reviews/edit" method="POST">
          <input type="hidden" name="reviewID" value="<%= review._id%>">
          <input type="hidden" name="movieID" value="<%= movie._id%>">
          <select name="rating">
            <% for (let i=1;i<=5;i++){%>
            <option value="<%=i%>" <%=review.rating===i?'selected':''%>><%=i%></option><%}%></select>
                </form></details>

        <form action="/review/del" method="POST" onsubmit="return confirm('Delete this review?')"><input type="hidden" name="reviewID" value="<%= review._id%>"><button type="submit">Delete</button></form>
        <%}%>
        <hr>
    </div>
  </section>
  <div class="movie-detail">

    <img src="movie.jpg">

    <div>
      <h2>Movie Title</h2>
      <p>Year Published - Duration</p>

      <div class="movie-meta">
        <div>Genre: Genre</div>
        <div>Average Rating: 0 / 5</div>
      </div>

      <p>Overview text placeholder.</p>

      <p><strong>Directed By</strong> Directors</p>

      <p><strong>Cast</strong> Cast, Cast</p>

      <div class="button-row">
        <a href="/watchlist"><button>Add to Watchlist</button></a>
        <a href="/watched"><button>Mark as Watched</button></a>
      </div>

    </div>

  </div>


  </section>

  <section>
    <div class="review-header">
      <a href="/review?movieID=<%=movie._id%>"><%= reviews.length%>Reviews</a>
      <a href="/review?movieID=<%=movie._id%>"><button>Add Review</button></a>
    </div>
  </section>

</body>

</html>