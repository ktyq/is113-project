<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Profile</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="stylesheet" href="/default.css">
</head>

<body>
  <%- include('partial/header', {user: user}) %>
  <h1>My Profile</h1>

  <p><strong>Username:</strong> <%= user.username %></p>
  <p><strong>Email:</strong> <%= user.email %></p>
  <p><strong>Role:</strong> <%= user.role %></p>

  <br>

  <% if (user.role === 'admin' || user.role === 'superadmin') { %>
    <!-- Admin actions -->
    <a href="/admin">Manage Movies</a>
    &nbsp;|&nbsp;
    <a href="/manage-accounts">Manage Accounts</a>
    &nbsp;|&nbsp;
    <a href="/edit-profile">Edit Profile</a>
  <% } else { %>
    <!-- User actions -->
    <a href="/edit-profile">Edit Profile</a>

    <br><br>
    <form action="/delete-profile" method="POST" id="deleteForm">
      <button type="button" onclick="confirmDelete()">Delete Account</button>
    </form>
  <% } %>
    

  <br><br>
  <form action="/logout" method="POST">
    <button type="submit">Logout</button>
  </form>

  <script>
    function confirmDelete() {
      if (confirm('Are you sure you want to delete your account?')) {
        document.getElementById('deleteForm').submit();
      }
    }
  </script>
</body>

</html>