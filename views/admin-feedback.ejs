<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Feedback Management</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="stylesheet" href="/default.css">
</head>

<body>
    <%- include('partial/header', { user: user }) %>

    <header>
        <h1>Feedback Management (Admin)</h1>
    </header>

    <main>
        <section>
            <hr>
            <% if (feedbacks && feedbacks.length > 0) { %>
                <table border="1">
                    <thead>
                        <tr>
                            <th>Submitted By</th>
                            <th>Type</th>
                            <th>Notes</th>
                            <th>URL</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% feedbacks.forEach(function(fb) { %>
                            <tr>
                                <td>
                                    <%= fb.sentBy && fb.sentBy.username ? fb.sentBy.username : 'Deleted User' %>
                                </td>
                                <td><%= fb.type %></td>
                                <td><%= fb.notes %></td>
                                <td>
                                    <% if (fb.url) { %>
                                        <a href="<%= fb.url %>">Link</a>
                                    <% } else { %>
                                        -
                                    <% } %>
                                </td>
                                <td><%= fb.status %></td>
                                <td><%= fb.createdAt.toLocaleDateString() %></td>
                                <td>
                                    <form action="/feedback/resolve/<%= fb._id %>" method="POST" style="display:inline;">
                                        <select name="status">
                                            <option value="pending" <%= fb.status === 'pending' ? 'selected' : '' %>>Pending</option>
                                            <option value="resolved" <%= fb.status === 'resolved' ? 'selected' : '' %>>Resolved</option>
                                        </select>
                                        <button type="submit">Update</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } else { %>
                <p>No feedback found.</p>
            <% } %>
        </section>
    </main>

    <br>
    <a href="/index">Back to Dashboard</a>
</body>

</html>