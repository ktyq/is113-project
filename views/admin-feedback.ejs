<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Feedback Management</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="stylesheet" href="/default.css">
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f4f9;
            margin: 0;
            padding: 20px;
            color: #333;
        }

        h2 {
            color: #2c3e50;
            margin-bottom: 15px;
        }

        section {
            background-color: #fff;
            padding: 20px;
            margin-bottom: 30px;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        .btn {
            padding: 8px 16px;
            border: none;
            color: white;
            font-size: 14px;
            border-radius: 6px;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

        .btn-success {
            background-color: #27ae60;
        }

        .btn-success:hover {
            background-color: #219a52;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

        table th, table td {
            padding: 12px 15px;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }

        table th {
            background-color: #2c3e50;
            color: white;
        }

        table tr:hover {
            background-color: #f5f5f5;
        }

        .status-pending {
            color: #e67e22;
            font-weight: bold;
        }

        .status-resolved {
            color: #27ae60;
            font-weight: bold;
        }

        .type-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: bold;
            color: white;
        }

        .type-feedback { background-color: #3498db; }
        .type-bug { background-color: #e74c3c; }
        .type-report { background-color: #9b59b6; }

        .empty-message {
            text-align: center;
            color: #999;
            padding: 30px;
        }

        @media (max-width: 600px) {
            table, thead, tbody, th, td, tr {
                display: block;
            }
            thead tr {
                display: none;
            }
            td {
                padding: 8px 15px;
                border: none;
            }
            td::before {
                content: attr(data-label);
                font-weight: bold;
                display: block;
                margin-bottom: 3px;
            }
            tr {
                border-bottom: 2px solid #ddd;
                margin-bottom: 10px;
            }
        }
    </style>
</head>

<body>
    <%- include('partial/header', { user: user }) %>

    <h1>Feedback Management (Admin)</h1>

    <!-- All Feedback List -->
    <section>
        <h2>All Feedback</h2>

        <% if (feedbacks && feedbacks.length > 0) { %>
            <table>
                <thead>
                    <tr>
                        <th>Submitted By</th>
                        <th>Type</th>
                        <th>Notes</th>
                        <th>URL</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% feedbacks.forEach(function(fb) { %>
                        <tr>
                            <td data-label="Submitted By">
                                <%= fb.sentBy && fb.sentBy.username ? fb.sentBy.username : 'Deleted User' %>
                            </td>
                            <td data-label="Type">
                                <span class="type-badge type-<%= fb.type %>"><%= fb.type %></span>
                            </td>
                            <td data-label="Notes"><%= fb.notes %></td>
                            <td data-label="URL">
                                <% if (fb.url) { %>
                                    <a href="<%= fb.url %>"><%= fb.url %></a>
                                <% } else { %>
                                    -
                                <% } %>
                            </td>
                            <td data-label="Status">
                                <span class="status-<%= fb.status %>"><%= fb.status %></span>
                            </td>
                            <td data-label="Date"><%= fb.createdAt.toLocaleDateString() %></td>
                            <td data-label="Actions">
                                <% if (fb.status === 'pending') { %>
                                    <form action="/feedback/resolve/<%= fb._id %>" method="POST">
                                        <button type="submit" class="btn btn-success">Resolve</button>
                                    </form>
                                <% } else { %>
                                    -
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } else { %>
            <p class="empty-message">No feedback found.</p>
        <% } %>
    </section>

</body>

</html>
